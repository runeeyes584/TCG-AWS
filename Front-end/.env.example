NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# Production realtime transport. When set, API Gateway WebSocket is preferred
# and NEXT_PUBLIC_SOCKET_URL is used only for local development.
# NEXT_PUBLIC_WS_URL=wss://example.execute-api.ap-southeast-1.amazonaws.com/prod
# NEXT_PUBLIC_MATCHMAKING_ROUTE=matchfinding-start

# Set this to an API Gateway HTTP endpoint backed by saveDeck Lambda in AWS.
# When omitted, the frontend uses NEXT_PUBLIC_API_URL/decks.
# NEXT_PUBLIC_SAVE_DECK_API_URL=https://example.execute-api.ap-southeast-1.amazonaws.com/decks
